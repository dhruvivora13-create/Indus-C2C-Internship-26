#include <iostream>
using namespace std;
class demo
{
    private:
      int n1,n2;
    public:
      demo(int a,int b)
    {
        n1=a;
        n2=b;
    }
    void display()
    {
    
      cout<<"n1 is"<<n1<<endl;
      cout<<"n2 is"<<n2<<endl;
    }
};
int main()
{
    int n1,n2;
    cout<< "Enter Value: "<<endl;
    cin>> n1;
    cout<< "Enter Value: "<<endl;
    cin>> n2;
    demo *d1=new demo(n1,n2);
    d1->display();
return 0;
}

OUTPUT: 
Enter Value: 
10
Enter Value: 
40
n1 is10
n2 is40




