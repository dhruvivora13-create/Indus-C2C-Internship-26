#include <iostream>
using namespace std;
class atm
{
    private:
        int balance;

    public:
        void withdraw(int amount)
        {
            cout << "ENTER BAL" << endl;
            cin >> balance;

            if(amount <= balance)
            {
                balance = balance - amount;

                cout << "amount withdraw successfully" << endl;
                cout << "Balance is:" << balance;
            }
            else
            {
                cout << "insufficient balance." << endl;
            }
        }

        void display()
        {
            cout << "balance is :" << balance << endl;
        }
};

int main()
{
    atm obj;
    obj.withdraw(4000);
    return 0;
}

OUTPUT:
ENTER BAL
5000
amount withdraw successfully
Balance is:1000


